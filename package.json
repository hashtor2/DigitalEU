{
  "name": "digitaleu",
  "version": "0.0.0",
  "private": true,
  "description": "Europeisk migrasjonsportal — flytt det digitale livet ditt til personvernvennlige, europeiske alternativer.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @digitaleu/web",
    "dev:scanner": "npm run dev --workspace @digitaleu/scanner",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "web": "npm run dev --workspace @digitaleu/web",
    "scanner": "npm run dev --workspace @digitaleu/scanner"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ai": "^6.0.208"
  }
}
