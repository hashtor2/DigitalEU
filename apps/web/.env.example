# Supabase — hentes fra prosjektets API-innstillinger (Settings → API).
# anon-nøkkelen er offentlig-by-design og beskyttes av Row Level Security (RLS).
# Kopier denne filen til `.env` og fyll inn. `.env` er gitignorert.
VITE_SUPABASE_URL="https://mwsalzjsvuvlmshxzbxg.supabase.co"
VITE_SUPABASE_ANON_KEY="<din-anon-public-key>"

# Google OAuth (Gmail Scanner)
VITE_GOOGLE_CLIENT_ID="646817279563-3qupgvhauv7i0shb9mpeuuerr5goldmg.apps.googleusercontent.com"

# Microsoft OAuth (Outlook Scanner) — Application (client) ID from Azure Entra ID App Registration
VITE_MICROSOFT_CLIENT_ID="<application-client-id-from-azure-portal>"

# Stripe Payments (client-side publishable key only — secret key belongs in Supabase Edge secrets, never here)
VITE_STRIPE_PUBLIC_KEY="pk_test_<your-test-key>"
VITE_STRIPE_CHECKOUT_SESSION_URL="https://mwsalzjsvuvlmshxzbxg.supabase.co/functions/v1/create-checkout"

# See docs/ENV_CONFIGURATION.md — VITE_* vars go on Vercel + apps/web/.env, NOT in Supabase.

# Plausible analytics (optional but recommended in production)
VITE_PLAUSIBLE_DOMAIN="digitaleu.me"
VITE_PLAUSIBLE_SCRIPT_SRC="https://plausible.io/js/script.js"

# MERK: service_role-nøkkelen skal ALDRI ligge i en VITE_-variabel eller i
# klientkoden. Den hører kun hjemme i server-/edge-miljø.
